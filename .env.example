# ── Anthropic API Key (Claude content generation for blog) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── GitHub (for pushing generated blog posts) ───────────────
GITHUB_TOKEN=ghp_xxxxx
GITHUB_OWNER=joelckeith-web
GITHUB_REPO=blog.viking-hvac
GITHUB_BRANCH=main

# ── Site URLs ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://blog.viking-hvac.com
NEXT_PUBLIC_MAIN_SITE_URL=https://www.viking-hvac.com

# ── Cron Secret (vercel cron auth) ──────────────────────────
CRON_SECRET=your-secret-here

# ── Optional: Google Indexing API ───────────────────────────
# GOOGLE_INDEXING_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Meta Pixel (blog + careers analytics) ───────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ──────────────────────────────────────────────────────────
# LANDING PAGES (lp.viking-hvac.com)
# ──────────────────────────────────────────────────────────

# SMTP for both careers and LP lead delivery (Gmail App Password)
SMTP_USER=joel.keith@aspbranding.com
SMTP_PASS=your-gmail-app-password

# Careers application recipients (comma-separated). Defaults to joel.keith@aspbranding.com.
CAREERS_EMAIL_TO=joel.keith@aspbranding.com

# LP lead recipients (comma-separated).
# Defaults: TO=joel.keith@aspbranding.com, CC=nikki@viking-hvac.com,valerie@viking-hvac.com,info@viking-hvac.com
LP_LEAD_TO=joel.keith@aspbranding.com
LP_LEAD_CC=nikki@viking-hvac.com,valerie@viking-hvac.com,info@viking-hvac.com

# Google reCAPTCHA v2 Checkbox (required in production)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Google Tag Manager (only loaded on lp.viking-hvac.com pages)
NEXT_PUBLIC_GTM_ID=

# ── Housecall Pro form swap ─────────────────────────────────
# When set, the LP form renders as an HCP booking iframe instead of the
# Nodemailer SMTP form. Use the public HCP booking URL.
# Leaving this blank keeps the SMTP path active.
NEXT_PUBLIC_HCP_FORM_URL=
